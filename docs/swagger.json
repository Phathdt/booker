{
    "swagger": "2.0",
    "info": {
        "description": "Centralized Exchange demo — token trading platform",
        "title": "Booker CEX API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost",
    "basePath": "/",
    "paths": {
        "/api/v1/auth/login": {
