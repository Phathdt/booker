{
  "name": "booker-e2e",
  "version": "0.0.1",
  "description": "End-to-End Testing Suite for Booker CEX Trading Platform",
  "private": true,
  "scripts": {
    "test": "cucumber-js --config .cucumber.js",
    "test:headed": "HEADLESS=false cucumber-js --config .cucumber.js",
    "test:debug": "DEBUG=* cucumber-js --config .cucumber.js",
    "test:smoke": "cucumber-js --config .cucumber.js --tags @smoke",
    "test:auth": "cucumber-js --config .cucumber.js --tags @auth",
    "test:trading": "cucumber-js --config .cucumber.js --tags @trading",
    "test:wallet": "cucumber-js --config .cucumber.js --tags @wallet",
    "clean": "rm -rf test-results",
    "setup": "playwright install chromium",
    "setup:all": "playwright install --with-deps chromium",
    "typecheck": "tsc --noEmit",
    "codegen": "playwright codegen http://booker.localhost"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "axios": "^1.7.3",
    "dotenv": "^16.4.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@playwright/test": "^1.47.0",
    "@types/node": "^22.4.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
