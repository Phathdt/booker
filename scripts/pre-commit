#!/bin/sh
# Pre-commit hook: format check only
# Build + tests are verified in CI/CD

set -e

echo "Running pre-commit checks..."

# Format check
echo "Checking Go formatting..."
UNFORMATTED=$(gofmt -l . 2>/dev/null | grep -v vendor | grep -v gen/ | head -5)
if [ -n "$UNFORMATTED" ]; then
    echo "ERROR: Unformatted Go files (run 'make format'):"
    echo "$UNFORMATTED"
    exit 1
fi

echo "All pre-commit checks passed!"
